rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - matches document ID
    //   - assets: list (optional) - user's assets
    //   - fundHoldings: map (optional) - cached mutual fund data
    //   - settings: map (optional) - user preferences
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isValidUserProfile() {
      return request.resource.data.keys().hasOnly(['uid', 'assets', 'fundHoldings', 'settings']) &&
             (!('uid' in request.resource.data) || request.resource.data.uid is string) &&
             (!('assets' in request.resource.data) || request.resource.data.assets is list) &&
             (!('fundHoldings' in request.resource.data) || request.resource.data.fundHoldings is map) &&
             (!('settings' in request.resource.data) || request.resource.data.settings is map);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile() && uidUnchanged();
      allow update: if isOwner(userId) && isValidUserProfile() && uidNotModified();
      allow delete: if isOwner(userId);
    }
  }
}
