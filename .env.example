# ==========================================
# Asset Tracker Environment Variables
# ==========================================

# 1. AI & LLM Keys
NEXT_PUBLIC_GEMINI_API_KEY="your_gemini_api_key_here"

# 2. Database & Sync
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/asset_tracker?retryWrites=true&w=majority"

# 3. Cryptocurrency Exchanges
BINANCE_API_KEY="your_binance_api_key"
BINANCE_SECRET="your_binance_api_secret"

COINDCX_API_KEY="your_coindcx_api_key"
COINDCX_SECRET="your_coindcx_api_secret"

# 4. Commodities & Metals
METALS_API_KEY="your_metals_api_key"

# 5. External APIs (Stocks & Mutual Funds)
INDIAN_API_ENDPOINTS="https://api1.example.com,https://api2.example.com"
INDIAN_API_KEYS="key1,key2"
MF_API_ENDPOINTS="https://mfapi.example.com"

# 6. Google Sheets Integration
GOOGLE_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourKeyHere\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID="your_google_sheet_id_here"
